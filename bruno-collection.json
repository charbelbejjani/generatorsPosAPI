{
  "name": "Generators POS API",
  "version": "1.0.0",
  "baseUrl": "http://localhost:4000",
  "requests": [
    {
      "name": "1. Login",
      "method": "POST",
      "url": "{{baseUrl}}/api/auth/login",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "username": "admin",
          "password": "password123"
        }
      },
      "description": "Login with username and password to get access and refresh tokens"
    },
    {
      "name": "2. Refresh Token",
      "method": "POST",
      "url": "{{baseUrl}}/api/auth/refresh",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "refresh_token": "{{refresh_token}}"
        }
      },
      "description": "Get a new access token using refresh token"
    },
    {
      "name": "3. Get Current User",
      "method": "GET",
      "url": "{{baseUrl}}/api/auth/me",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Get current authenticated user information"
    },
    {
      "name": "4. Logout",
      "method": "POST",
      "url": "{{baseUrl}}/api/auth/logout",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "refresh_token": "{{refresh_token}}"
        }
      },
      "description": "Logout and revoke refresh token"
    },
    {
      "name": "5. Change Password",
      "method": "POST",
      "url": "{{baseUrl}}/api/auth/change-password",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "current_password": "old_password",
          "new_password": "new_password"
        }
      },
      "description": "Change user password (requires current password)"
    },
    {
      "name": "6. Get All Users",
      "method": "GET",
      "url": "{{baseUrl}}/api/users",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Get all users (requires authentication and read permission)"
    },
    {
      "name": "7. Get User By ID",
      "method": "GET",
      "url": "{{baseUrl}}/api/users/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Get a specific user by ID (requires authentication and read permission)"
    },
    {
      "name": "8. Create User",
      "method": "POST",
      "url": "{{baseUrl}}/api/users",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "first_name": "John",
          "last_name": "Doe",
          "username": "johndoe",
          "password": "password123",
          "email": "john@example.com",
          "group_id": 2
        }
      },
      "description": "Create a new user (requires authentication and add permission)"
    },
    {
      "name": "Get All Currencies",
      "method": "GET",
      "url": "{{baseUrl}}/api/currencies",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Get all currencies"
    },
    {
      "name": "Get Currency By ID",
      "method": "GET",
      "url": "{{baseUrl}}/api/currencies/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Get a specific currency by ID"
    },
    {
      "name": "Create Currency",
      "method": "POST",
      "url": "{{baseUrl}}/api/currencies",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "description": "US Dollar",
          "symbol": "$",
          "active": true
        }
      },
      "description": "Create a new currency. description must be unique."
    },
    {
      "name": "Update Currency",
      "method": "PUT",
      "url": "{{baseUrl}}/api/currencies/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "symbol": "$",
          "active": true
        }
      },
      "description": "Update symbol and/or active status of a currency. description is immutable."
    },
    {
      "name": "Delete Currency",
      "method": "DELETE",
      "url": "{{baseUrl}}/api/currencies/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Delete a currency by ID"
    },
    {
      "name": "Get All Schedules",
      "method": "GET",
      "url": "{{baseUrl}}/api/schedules",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Get all payment schedules ordered by year and month"
    },
    {
      "name": "Get Schedule By ID",
      "method": "GET",
      "url": "{{baseUrl}}/api/schedules/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Get a specific payment schedule by ID"
    },
    {
      "name": "Create Schedule",
      "method": "POST",
      "url": "{{baseUrl}}/api/schedules",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "month": 4,
          "year": 2026,
          "description": "April 2026",
          "cost": 150000,
          "kwCost": 5000,
          "dollarRate": 89500,
          "active": true
        }
      },
      "description": "Create a new payment schedule. month+year combination must be unique."
    },
    {
      "name": "Update Schedule",
      "method": "PUT",
      "url": "{{baseUrl}}/api/schedules/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "description": "April 2026 Updated",
          "cost": 160000,
          "kwCost": 5500,
          "dollarRate": 90000,
          "active": true
        }
      },
      "description": "Update a schedule. month and year are immutable after creation."
    },
    {
      "name": "Delete Schedule",
      "method": "DELETE",
      "url": "{{baseUrl}}/api/schedules/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Delete a payment schedule by ID"
    },
    {
      "name": "Get All Phone Codes",
      "method": "GET",
      "url": "{{baseUrl}}/api/phone-codes",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Get all phone codes ordered by number"
    },
    {
      "name": "Get Phone Code By ID",
      "method": "GET",
      "url": "{{baseUrl}}/api/phone-codes/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Get a specific phone code by ID"
    },
    {
      "name": "Create Phone Code",
      "method": "POST",
      "url": "{{baseUrl}}/api/phone-codes",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "number": "03",
          "type": 2
        }
      },
      "description": "Create a new phone code. number+type must be unique. type: 1=Land-line, 2=Mobile."
    },
    {
      "name": "Update Phone Code",
      "method": "PUT",
      "url": "{{baseUrl}}/api/phone-codes/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "number": "03",
          "type": 2,
          "active": 1
        }
      },
      "description": "Update a phone code. active: 1=active, 0=inactive. type: 1=Land-line, 2=Mobile."
    },
    {
      "name": "Delete Phone Code",
      "method": "DELETE",
      "url": "{{baseUrl}}/api/phone-codes/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Delete a phone code by ID"
    },
    {
      "name": "Get All User Groups",
      "method": "GET",
      "url": "{{baseUrl}}/api/user-groups",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Get all user groups ordered by name"
    },
    {
      "name": "Get User Group By ID",
      "method": "GET",
      "url": "{{baseUrl}}/api/user-groups/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Get a specific user group by ID"
    },
    {
      "name": "Create User Group",
      "method": "POST",
      "url": "{{baseUrl}}/api/user-groups",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "name": "Managers",
          "active": true
        }
      },
      "description": "Create a new user group. name must be unique."
    },
    {
      "name": "Update User Group",
      "method": "PUT",
      "url": "{{baseUrl}}/api/user-groups/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "name": "Managers Updated",
          "active": true
        }
      },
      "description": "Update a user group. Cannot set active=false if users are assigned to this group."
    },
    {
      "name": "Delete User Group",
      "method": "DELETE",
      "url": "{{baseUrl}}/api/user-groups/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Delete a user group. Cannot delete if users are assigned to this group."
    },
    {
      "name": "Get All Pages",
      "method": "GET",
      "url": "{{baseUrl}}/api/pages",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Get all pages ordered by section name then page name. Includes section name."
    },
    {
      "name": "Get Page By ID",
      "method": "GET",
      "url": "{{baseUrl}}/api/pages/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Get a specific page by ID (includes section name)"
    },
    {
      "name": "Create Page",
      "method": "POST",
      "url": "{{baseUrl}}/api/pages",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "name": "Dashboard",
          "url": "dashboard.php",
          "sectionId": 1
        }
      },
      "description": "Create a new page. name must be unique. sectionId must reference an existing section."
    },
    {
      "name": "Update Page",
      "method": "PUT",
      "url": "{{baseUrl}}/api/pages/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        },
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "type": "json",
        "json": {
          "name": "Dashboard Updated",
          "url": "dashboard.php",
          "sectionId": 1,
          "active": true
        }
      },
      "description": "Update a page's name, url, sectionId and/or active status."
    },
    {
      "name": "Delete Page",
      "method": "DELETE",
      "url": "{{baseUrl}}/api/pages/1",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {{access_token}}"
        }
      ],
      "description": "Delete a page. Cannot delete if user rights are assigned to this page."
    }
  ],
  "environments": [
    {
      "name": "Local",
      "variables": {
        "baseUrl": "http://localhost:4000",
        "access_token": "",
        "refresh_token": ""
      }
    }
  ]
}
