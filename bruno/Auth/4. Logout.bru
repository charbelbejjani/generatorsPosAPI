meta {
  name: 4. Logout
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/auth/logout
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "refresh_token": "{{refresh_token}}"
  }
}

docs {
  Logout and revoke the refresh token.
  
  This invalidates the refresh token in the database.
  Access token will still work until it expires.
}
