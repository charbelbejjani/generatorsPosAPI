meta {
  name: Delete Amperage
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/api/amperages/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

docs {
  Deactivate (soft delete) an amperage.
  
  Change the ID in the URL as needed.
  
  Note: Cannot delete if assigned to clients.
  
  Requires:
  - Authentication (valid access token)
  - Delete permission on amperage page
}
