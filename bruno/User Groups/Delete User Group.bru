meta {
  name: Delete User Group
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/api/user-groups/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

docs {
  Delete a user group by ID.

  Change the ID in the URL as needed.

  Note: Cannot delete if users are assigned to this group.

  Requires:
  - Authentication (valid access token)
  - Delete permission on user groups page (page ID 1)
}
