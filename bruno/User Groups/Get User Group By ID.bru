meta {
  name: Get User Group By ID
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/user-groups/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

docs {
  Get a specific user group by ID.

  Change the ID in the URL as needed.

  Requires:
  - Authentication (valid access token)
  - Read permission on user groups page (page ID 1)
}
