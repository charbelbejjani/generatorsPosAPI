meta {
  name: Get Currency By ID
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/currencies/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

docs {
  Get a specific currency by ID.

  Change the ID in the URL as needed.

  Requires:
  - Authentication (valid access token)
  - Read permission on currencies page
}
