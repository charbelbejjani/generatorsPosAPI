meta {
  name: Delete Zone
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/api/zones/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

docs {
  Deactivate (soft delete) a zone.
  
  Change the ID in the URL as needed.
  
  Note: Cannot delete if has active clients.
  Returns 204 No Content on success.
  
  Requires:
  - Authentication (valid access token)
  - Delete permission on zones page
}
